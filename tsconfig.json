{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "legacy",
    "tmp",
    "app/auth/**",
    "app/capstones/**",
    "app/dashboard/**",
    "app/exams/**",
    "app/lessons/**",
    "app/resources/**",
    "app/page.tsx",
    "components/navbar.tsx",
    "components/footer.tsx",
    "components/dashboard/**",
    "lib/data/**",
    "lib/context/**"
  ]
}
