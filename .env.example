# Copy to .env.local and fill in real values. Never commit the real file.
# See CLAUDE.md § Environment for what each key is used for.

# ----- Supabase (required for auth + progress sync) -----
# URL of your Supabase project. Public — shipped to browser.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Publishable key (new Supabase key system, starts with `sb_publishable_...`).
# Public — shipped to browser. RLS policies are what actually secure data.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only keys. Never expose to the browser. Used by server components /
# route handlers that need elevated access (none today — reserved for future
# admin operations and the planned profile-migration server action).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=...

# ----- Postgres direct connection (from Vercel + Supabase integration) -----
# Populated automatically by the Vercel + Supabase integration. Not used by
# app code today, but kept for future Drizzle/Prisma migrations or SQL scripts.
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...
POSTGRES_USER=postgres
POSTGRES_HOST=...
POSTGRES_PASSWORD=...
POSTGRES_DATABASE=postgres

# ----- Gemini (optional — only needed for AI writing/speaking evaluation) -----
# The app is fully functional without this. Unset = AI panels hide.
GEMINI_API_KEY=
